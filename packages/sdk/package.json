{
  "name": "@originals/sdk",
  "version": "2.0.0",
  "description": "TypeScript SDK for the Originals Protocol - creating, discovering, and transferring digital assets with cryptographically verifiable provenance",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "originals-cel": "./dist/cel/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./core/*": {
      "types": "./dist/core/*.d.ts",
      "import": "./dist/core/*.js"
    },
    "./did/*": {
      "types": "./dist/did/*.d.ts",
      "import": "./dist/did/*.js"
    },
    "./vc/*": {
      "types": "./dist/vc/*.d.ts",
      "import": "./dist/vc/*.js"
    },
    "./vc/cryptosuites/*": {
      "types": "./dist/vc/cryptosuites/*.d.ts",
      "import": "./dist/vc/cryptosuites/*.js"
    },
    "./bitcoin/*": {
      "types": "./dist/bitcoin/*.d.ts",
      "import": "./dist/bitcoin/*.js"
    },
    "./lifecycle/*": {
      "types": "./dist/lifecycle/*.d.ts",
      "import": "./dist/lifecycle/*.js"
    },
    "./crypto/*": {
      "types": "./dist/crypto/*.d.ts",
      "import": "./dist/crypto/*.js"
    },
    "./resources/*": {
      "types": "./dist/resources/*.d.ts",
      "import": "./dist/resources/*.js"
    },
    "./storage/*": {
      "types": "./dist/storage/*.d.ts",
      "import": "./dist/storage/*.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/types/*.js"
    },
    "./utils/*": {
      "types": "./dist/utils/*.d.ts",
      "import": "./dist/utils/*.js"
    }
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "typecheck": "tsc --noEmit -p .",
    "prepublishOnly": "npm run build",
    "test": "bun test tests/integration && bun test tests/unit && bun test tests/security && bun test tests/stress",
    "test:coverage": "bun test tests/integration tests/unit --coverage",
    "check-coverage": "bun run ../../scripts/check-coverage.ts",
    "test:ci": "bash -o pipefail -c 'bun test tests/integration tests/unit --coverage 2>&1 | bun run ../../scripts/check-coverage.ts'",
    "test:security": "bun test tests/security",
    "test:stress": "bun test tests/stress",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "originals",
    "did",
    "verifiable-credentials",
    "bitcoin",
    "ordinals",
    "digital-assets",
    "provenance",
    "decentralized-identity"
  ],
  "author": "Aviary Tech",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/onionoriginals/sdk"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "dependencies": {
    "@aviarytech/did-peer": "^1.1.2",
    "@noble/curves": "^2.2.0",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.0.1",
    "@noble/secp256k1": "^3.1.0",
    "@scure/base": "^2.2.0",
    "@scure/btc-signer": "^2.2.0",
    "b58": "^4.0.3",
    "bitcoinjs-lib": "^6.1.0",
    "cborg": "^5.1.6",
    "didwebvh-ts": "^2.8.0",
    "jsonld": "^8.3.3",
    "micro-ordinals": "^0.2.2",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bun": "^1.3.0",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "bun-types": "^1.3.1",
    "eslint": "^10.6.0",
    "prettier": "^3.0.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
