# Turnkey parent-org API credentials (server-only)
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=
TURNKEY_ORGANIZATION_ID=
# Optional: defaults to https://api.turnkey.com
TURNKEY_API_BASE_URL=

# JWT signing secret for the session cookie
JWT_SECRET=

# Domain used for did:webvh creation (e.g. magby.originals.build)
WEBVH_DOMAIN=magby.originals.build

# Server port (default 8787)
PORT=8787

# ─── Real testnet4 inscription (Track B) — all optional ──────────────────────
# When these are set, the demo's Inscribe step does a REAL Bitcoin testnet4
# inscription (worthless tBTC). Absent → inscribe stays on the mock provider.
#
# QuickNode testnet4 endpoint WITH the Ordinals & Runes add-on. Required for the
# ordinals-aware sat lookup (getFirstSatOfOutput) + fee + broadcast. Confirm the
# add-on covers testnet4 first: `bun run apps/landing/scripts/check-quicknode-ordinals.ts`.
QUICKNODE_ENDPOINT=

# The faucet: a funded testnet4 P2WPKH (tb1q…) address that funds each user's
# inscription. Pick ONE signing method:
#   (a) Raw key (simplest): the address's WIF (testnet, starts with 'c'/'9').
BTC_FAUCET_WIF=
#   (b) Turnkey-org wallet: the wallet id holding the address (no raw key).
# BTC_FAUCET_WALLET_ID=
# The tb1q… address itself (with a raw WIF this is derived + verified from it).
BTC_FAUCET_ADDRESS=
# Sats sent to the user per inscription (default 20000).
BTC_FAUCET_SATS=20000
# Optional override for the faucet's UTXO source (default mempool.space testnet4).
# MEMPOOL_TESTNET4_API=https://mempool.space/testnet4/api

# ─── Browser build-time flag (set BEFORE `bun run build`) ────────────────────
# Flips the demo engine from the mock provider to the real testnet4 path.
# Vite bakes this at build time — you MUST rebuild the SPA after setting it.
VITE_BTC_TESTNET=1
